# rtylr self-host environment.
#
# Copy this file to .env (./scripts/setup.sh does this for you and generates
# secrets) and replace every change_me value before exposing the stack outside
# your machine.

# ---------------------------------------------------------------------------
# Image selection
# ---------------------------------------------------------------------------
# A single version pins ALL images (backend + frontends) to the same tag.
# This value is also kept in versions.env; .env wins for Compose.
RTYLR_VERSION=1.0.0
RTYLR_IMAGE_REGISTRY=docker.io
RTYLR_IMAGE_NAMESPACE=rtylr

# ---------------------------------------------------------------------------
# Routing / base domain
# ---------------------------------------------------------------------------
# With RTYLR_DOMAIN=localhost the apps run at http://auth.localhost,
# http://dash.localhost, etc. For production set this to your real domain and
# create DNS records for each subdomain (see docs/dns.md).
RTYLR_DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Configurable app URLs (no hosted domains are hardcoded in any image)
# ---------------------------------------------------------------------------
# Frontends
AUTH_URL=http://auth.localhost
DASH_URL=http://dash.localhost
POS_URL=http://pos.localhost
ERP_URL=http://erp.localhost
HR_URL=http://hr.localhost
CRM_URL=http://crm.localhost
FINANCE_URL=http://finance.localhost
FLOW_URL=http://flow.localhost
INSIGHTS_URL=http://insights.localhost
RECRUIT_URL=http://recruit.localhost
MENU_URL=http://menu.localhost
# Backend + media
API_URL=http://api.localhost
UPLOAD_URL=http://upload.localhost

# ---------------------------------------------------------------------------
# License (self-hosted)
# ---------------------------------------------------------------------------
# Your rtylr license key (provided by Voxire).
RTYLR_LICENSE_KEY=
DEPLOYMENT_MODE=self_hosted
APP_ENV=production

# ---------------------------------------------------------------------------
# Secrets (generated by ./scripts/setup.sh)
# ---------------------------------------------------------------------------
JWT_SECRET=change_me_at_least_32_random_characters
INTERNAL_TOKEN=change_me_internal_service_token
CDN_API_KEY=change_me_upload_service_key

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Bring your own MySQL by pointing DB_HOST at it and leaving the local `db`
# service out of the `local-infra` profile. To use the bundled MySQL, keep
# DB_HOST=db and start the stack with the `local-infra` profile (default in
# ./scripts/setup.sh output).
DB_HOST=db
DB_PORT=3306
DB_NAME=rtylr_self_host
DB_USER=rtylr_user
DB_PASSWORD=change_me_mysql_password
# Only used by the bundled MySQL container (local-infra profile).
MYSQL_DATABASE=rtylr_self_host
MYSQL_USER=rtylr_user
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password

# ---------------------------------------------------------------------------
# Cache (Redis)
# ---------------------------------------------------------------------------
# Bring your own Redis by pointing REDIS_URL at it. To use the bundled Redis,
# keep redis:6379 and run the `local-infra` profile.
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# Object storage (S3-compatible)
# ---------------------------------------------------------------------------
# Bring your own S3-compatible storage (AWS S3, MinIO, etc.) by setting the
# values below to your endpoint/bucket/credentials. To use the bundled local
# floci object storage, keep the defaults and run the `local-infra` profile.
S3_BUCKET_NAME=rtylr-self-host
S3_REGION=us-east-1
S3_ENDPOINT=http://floci:4566
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=rtylr
AWS_SECRET_ACCESS_KEY=change_me_floci_secret
# Used by the bundled floci init job to create the bucket.
FLOCI_BUCKET=rtylr-self-host

# Upload service tuning.
CDN_MAX_UPLOAD_MB=100

# ---------------------------------------------------------------------------
# Optional observability and integrations (passthrough)
# ---------------------------------------------------------------------------
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=rtylr-self-host
RESEND_API_KEY=
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_BASE_URL=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_NIM_API_KEY=
AI_PRIMARY_PROVIDER=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=
PADDLE_SANDBOX=true
